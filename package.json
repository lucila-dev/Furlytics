{
  "name": "furlytics",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/migrate-with-retry.js && prisma generate && next build",
    "db:migrate:deploy": "node scripts/migrate-with-retry.js",
    "start": "next start",
    "preview": "npm run build && npm run start",
    "lint": "eslint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed"
  },
  "prisma": {
    "seed": "npx ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  },
  "dependencies": {
    "@neondatabase/auth": "^0.4.2-beta",
    "@prisma/client": "^6",
    "bcryptjs": "^2",
    "jspdf": "^4.1.0",
    "next": "16.1.6",
    "openai": "^4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "zod": "^3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "prisma": "^6",
    "tailwindcss": "^4",
    "ts-node": "^10",
    "typescript": "^5"
  }
}
